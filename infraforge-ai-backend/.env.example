# Copy this file to .env and fill in real values. Never commit the real .env.

# MongoDB connection (required)
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster-host>/?appName=<app>
DATABASE_NAME=infraforge_marketplace

# ---------------------------------------------------------------------------
# AI provider — Groq/local default; OpenAI OFF until final polish testing
# ---------------------------------------------------------------------------
AI_PROVIDER=groq
ENABLE_OPENAI=false
# llm_first = Groq/OpenAI primary intent brain; rules_first = legacy (default)
AI_INTENT_MODE=llm_first
INTENT_CACHE_TTL_SECONDS=120
# Post-tool response polish (Siri/Assistant style) — default ON; does NOT affect search/routing.
# Requires GROQ_API_KEY; falls back to local templates if LLM fails or set false.
USE_LLM_RESPONSE_GENERATION=true

# Structured per-request JSON trace for /chat (logs only; no response shape change)
ASSISTANT_DEBUG=false

GROQ_API_KEY=your_groq_api_key_here

# Leave blank during development — preserves purchased credits
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Feature flags — all false = zero extra LLM cost on chat/RAG/advisor
USE_GROQ_TEXT_UNDERSTANDING=false
USE_GROQ_ADVISOR=false
USE_GROQ_RAG_ANSWER=false
USE_GROQ_INTENT_CLASSIFIER=false
USE_GROQ_UNIVERSAL_CLASSIFIER=auto
USE_GROQ_MESSAGE_NORMALIZER=false
USE_OPENAI_INTENT_PARSER=false
WARMUP_EMBEDDING_ON_STARTUP=true

# Support handover (optional)
SUPPORT_PHONE=+91-1800-000-0000
SUPPORT_WHATSAPP=+91-1800-000-0000
SUPPORT_EMAIL=support@infraforge.in

ENVIRONMENT=development

# Deploy: comma-separated frontend URLs allowed to call this API (CORS).
# Example: CORS_ORIGINS=https://infraforge.vercel.app,https://www.yourdomain.com
CORS_ORIGINS=

UPLOAD_DIR=uploads
AUDIO_UPLOAD_DIR=uploads/audio

# Voice Phase V1 — set VOICE_PIPELINE_V2=true after parity tests pass
VOICE_PIPELINE_V2=false
VOICE_MAX_FILE_SIZE_MB=10
VOICE_MAX_DURATION_SECONDS=120
VOICE_STT_TIMEOUT_SECONDS=45
VOICE_MAX_CONCURRENT_TRANSCRIPTIONS=3
# Optional STT language hint: en, hi, etc. Leave blank for auto-detect.
VOICE_STT_LANGUAGE_HINT=
IMAGE_SEARCH_UPLOAD_DIR=uploads/image_search
RAG_PDF_UPLOAD_DIR=uploads/rag_pdfs

# YOLO image search (after train_yolo_classifier.py)
YOLO_MODEL_PATH=models/infraforge_yolov8n_cls/best.pt
IMAGE_CLASSIFIER=auto
