# Copy this file to .env and fill in real values. Never commit the real .env.

# MongoDB connection (required)
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster-host>/?appName=<app>
# Use the marketplace database name after importing marketplace_mongo_dump
DATABASE_NAME=infraforge_marketplace

# Groq API key (required for chatbot, voice, text understanding, RAG answers)
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API key (optional — used by intent extraction if present)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Runtime environment
ENVIRONMENT=development

# Upload directories (optional — sensible defaults are used if unset)
UPLOAD_DIR=uploads
AUDIO_UPLOAD_DIR=uploads/audio
IMAGE_SEARCH_UPLOAD_DIR=uploads/image_search
RAG_PDF_UPLOAD_DIR=uploads/rag_pdfs

# YOLO image search (after train_yolo_classifier.py)
YOLO_MODEL_PATH=models/infraforge_yolov8n_cls/best.pt
IMAGE_CLASSIFIER=auto
